DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/learn_english_db
POSTGRES_DB=learn_english_db

REDIS_URL=redis://localhost:6379/0

SECRET_KEY=change-this-secret-key-in-production-min-32-chars
ANON_SALT=change-this-anonymous-salt
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

AI_PROVIDER=huggingface
HUGGINGFACE_API_KEY=your-huggingface-api-key-here
HUGGINGFACE_MODEL=microsoft/Phi-3-mini-4k-instruct

FREE_TIER_DAILY_LIMIT=50
FREE_TIER_MONTHLY_LIMIT=1000
FREE_TIER_WORD_LIMIT=3
PREMIUM_TIER_DAILY_LIMIT=500
PREMIUM_TIER_MONTHLY_LIMIT=50000

# RevenueCat (webhook Authorization header must match REVENUECAT_WEBHOOK_SECRET)
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret
REVENUECAT_API_KEY=your-revenuecat-secret-api-key

CACHE_TTL_SECONDS=3600

LOG_LEVEL=INFO